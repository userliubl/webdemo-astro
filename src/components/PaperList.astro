---
import Section from "./Section.astro";
import { papers } from "@/data/site";
---
<Section id="papers" title="论文和工作" eyebrow="Publications & Work" hasAction>
  <a
    slot="action"
    href="/works/"
    class="inline-flex rounded border border-imu-brand/20 bg-white/90 px-4 py-2 text-sm font-medium text-imu-brand-deep transition hover:border-imu-highlight/60 hover:text-imu-brand"
  >
    更多
  </a>
  <ol class="space-y-4">
    {papers.map((paper, index) => (
      <li class="relative rounded-lg border border-slate-200 bg-white p-5 shadow-card transition duration-200 hover:z-10 hover:scale-[1.02] hover:border-imu-highlight/50 motion-reduce:hover:scale-100 sm:p-6">
        <div class="flex flex-wrap items-start gap-3">
          <span class="mt-0.5 font-mono text-xs text-imu-brand/40 tabular-nums">
            {String(index + 1).padStart(2, "0")}
          </span>
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-2">
              {paper.tag && (
                <span class="rounded border border-imu-highlight/35 bg-imu-50 px-2 py-0.5 text-xs font-medium text-imu-brand-deep">
                  {paper.tag}
                </span>
              )}
              <span class="text-xs text-slate-500">{paper.venue} · {paper.year}</span>
            </div>
            <h3 class="mt-2 text-base font-medium leading-snug text-slate-900 sm:text-lg">
              {paper.link ? (
                <a
                  href={paper.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-imu-brand-deep underline decoration-imu-highlight/40 underline-offset-[5px] transition hover:text-imu-brand hover:decoration-imu-highlight"
                >
                  {paper.title}
                </a>
              ) : (
                paper.title
              )}
            </h3>
            <p class="mt-2 text-sm text-slate-600">{paper.authors}</p>
          </div>
        </div>
      </li>
    ))}
  </ol>
</Section>
