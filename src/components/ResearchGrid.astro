---
import Section from "./Section.astro";
import { getLangFromPath, getSiteData } from "@/data/site";
const lang = getLangFromPath(Astro.url.pathname);
const { researchAreas } = getSiteData(lang);
---
<Section id="research" title={researchAreas.title} eyebrow={researchAreas.eyebrow} variant="brand" hasAction>
  <a
    slot="action"
    href="#papers"
    class="inline-flex rounded border border-white px-4 py-1.5 text-sm font-medium text-white transition hover:bg-white/10"
  >
    {researchAreas.more}
  </a>
  <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" data-reveal-stagger>
    {researchAreas.items.map((item) => (
      <li
        data-reveal
        class="group relative flex h-full flex-col rounded-xl border border-white/55 bg-white/98 p-5 shadow-card-brand ring-1 ring-white/25 backdrop-blur-[2px] transition duration-200 hover:z-10 hover:-translate-y-0.5 hover:border-white hover:bg-white hover:shadow-xl hover:shadow-imu-brand/20 motion-reduce:hover:translate-y-0 dark:border-slate-700 dark:bg-slate-800/90 dark:shadow-slate-950/30 dark:hover:border-slate-600 dark:hover:bg-slate-800"
      >
        <span class="mb-3 block h-0.5 w-8 rounded-full bg-gradient-to-r from-imu-highlight to-imu-highlight/40 transition-[width,opacity] duration-200 group-hover:w-12 group-hover:opacity-100" aria-hidden></span>
        <h3 class="text-base font-semibold text-slate-900 dark:text-slate-100">{item.name}</h3>
        <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-600 dark:text-slate-400">{item.summary}</p>
      </li>
    ))}
  </ul>
</Section>
