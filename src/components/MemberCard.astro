---
import type { Person } from "@/data/site";
interface Props {
  person: Person;
  featured?: boolean;
}
const { person, featured = false } = Astro.props;
const badge = person.name.slice(0, 2);
---
<li
  data-reveal
  class={`group relative flex flex-col rounded-lg border bg-white transition duration-200 hover:z-10 hover:scale-[1.02] motion-reduce:hover:scale-100 dark:bg-slate-800/90 dark:hover:bg-slate-800 ${
    featured
      ? "border-imu-highlight/25 shadow-card hover:border-imu-highlight/60 dark:border-imu-highlight/30 dark:shadow-slate-950/30"
      : "border-slate-200 shadow-card hover:border-imu-400/60 dark:border-slate-700 dark:shadow-slate-950/20 dark:hover:border-slate-500"
  }`}
>
  <div class="flex items-start gap-4 p-5">
    <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-imu-brand via-imu-brand-deep to-imu-highlight text-lg font-semibold text-white shadow-sm">
      {badge}
    </div>
    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-baseline justify-between gap-2">
        <span class="text-lg font-semibold text-slate-900 dark:text-slate-100">{person.name}</span>
        <span class="rounded border border-imu-200 bg-imu-50 px-2.5 py-0.5 text-xs font-medium text-imu-800 dark:border-imu-800 dark:bg-imu-900/40 dark:text-imu-300">
          {person.role}
        </span>
      </div>
      {person.title && <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">{person.title}</p>}
      {person.focus && <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">{person.focus}</p>}
      {person.email && (
        <a
          href={`mailto:${person.email}`}
          class="mt-4 inline-flex text-sm font-medium text-imu-700 underline-offset-2 hover:text-imu-900 hover:underline dark:text-imu-400 dark:hover:text-imu-300"
        >
          {person.email}
        </a>
      )}
    </div>
  </div>
</li>
