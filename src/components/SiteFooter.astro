---
import { getLangFromPath, getSiteData } from "@/data/site";
const lang = getLangFromPath(Astro.url.pathname);
const { footer, siteMeta, footerLabels } = getSiteData(lang);
const year = new Date().getFullYear();
---
<footer
  id="footer"
  class="border-t border-white/10 bg-brand-darker-photo bg-cover bg-center px-4 py-12 text-white sm:px-6"
>
  <div class="mx-auto max-w-5xl">
    <div class="grid gap-10 border-b border-white/10 pb-10 sm:grid-cols-2 lg:grid-cols-3 lg:gap-12">
      <div>
        <h3 class="mb-4 text-sm font-semibold tracking-wide text-white">{footer.headline}</h3>
        <ul class="space-y-3 text-sm leading-relaxed">
          <li>
            <span class="text-white">{footerLabels.address}</span>
            <p class="mt-0.5 text-white">{footer.address}</p>
          </li>
          <li>
            <span class="text-white">{footerLabels.postalCode}</span>
            <p class="mt-0.5 text-white">{footer.postalCode}</p>
          </li>
          <li>
            <span class="text-white">{footerLabels.phone}</span>
            <p class="mt-0.5 text-white">{footer.phone}</p>
          </li>
          <li>
            <span class="text-white">{footerLabels.email}</span>
            <p class="mt-0.5">
              <a href={`mailto:${footer.email}`} class="text-white underline-offset-2 hover:text-white/85 hover:underline">
                {footer.email}
              </a>
            </p>
          </li>
          <li>
            <span class="text-white">{footerLabels.officeHours}</span>
            <p class="mt-0.5 text-white">{footer.officeHours}</p>
          </li>
        </ul>
        <p class="mt-4 text-xs leading-relaxed text-white">{footer.note}</p>
      </div>

      <div>
        <h3 class="mb-4 text-sm font-semibold tracking-wide text-white">{footerLabels.links}</h3>
        <ul class="space-y-2.5 text-sm">
          {footer.relatedLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-white underline-offset-2 transition hover:text-white/85 hover:underline"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <p class="mt-6 text-xs leading-relaxed text-white">
          {footerLabels.staticNote}
          <code class="rounded bg-white/5 px-1 py-0.5 font-mono text-[11px] text-white">src/data/site.ts</code>
          {lang === "en" ? "." : "中维护。"}
        </p>
      </div>

      <div class="sm:col-span-2 lg:col-span-1">
        <h3 class="mb-4 text-sm font-semibold tracking-wide text-white">{footerLabels.aboutSite}</h3>
        <p class="text-sm leading-relaxed text-white">{siteMeta.description}</p>
        <p class="mt-4 text-xs text-white">{footerLabels.keywords}：{siteMeta.keywords.join(" · ")}</p>
      </div>
    </div>

    <div class="flex flex-col gap-3 pt-8 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm text-white">
        © {year} {siteMeta.title}
        <span class="mx-2 text-white">|</span>
        <span class="text-white">{footerLabels.icp}</span>
      </p>
      <p class="font-mono text-xs text-white">Astro static</p>
    </div>
  </div>
</footer>
