---
import { getLangFromPath, getSiteData } from "@/data/site";
const lang = getLangFromPath(Astro.url.pathname);
const { ui } = getSiteData(lang);
---
<button
  type="button"
  data-back-to-top
  aria-label={ui.backToTop}
  class="pointer-events-none fixed bottom-6 right-6 z-[60] flex h-11 w-11 translate-y-2 items-center justify-center rounded-full border border-white/20 bg-imu-highlight text-white opacity-0 shadow-lg shadow-imu-brand-deep/25 transition hover:brightness-110 focus:outline-none focus-visible:ring-2 focus-visible:ring-imu-highlight focus-visible:ring-offset-2 dark:shadow-imu-brand/30 dark:focus-visible:ring-offset-slate-900 sm:bottom-8 sm:right-8"
>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden>
    <path d="M6 14l6-6 6 6" stroke-linecap="round" stroke-linejoin="round"></path>
  </svg>
</button>

<script>
  const btn = document.querySelector<HTMLButtonElement>("[data-back-to-top]");
  if (btn) {
    const SHOW_AFTER = 320;
    const update = () => {
      const visible = window.scrollY > SHOW_AFTER;
      btn.classList.toggle("opacity-0", !visible);
      btn.classList.toggle("translate-y-2", !visible);
      btn.classList.toggle("pointer-events-none", !visible);
      btn.classList.toggle("opacity-100", visible);
      btn.classList.toggle("translate-y-0", visible);
    };
    update();
    window.addEventListener("scroll", update, { passive: true });
    btn.addEventListener("click", () =>
      window.scrollTo({ top: 0, behavior: "smooth" }),
    );
  }
</script>
