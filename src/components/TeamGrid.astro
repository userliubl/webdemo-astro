---
import Section from "./Section.astro";
import MemberCard from "./MemberCard.astro";
import { getLangFromPath, getSiteData } from "@/data/site";
const lang = getLangFromPath(Astro.url.pathname);
const { people, team } = getSiteData(lang);
---
<Section id="people" title={team.title} eyebrow={team.eyebrow} hasAction>
  <a
    slot="action"
    href="#people"
    class="inline-flex rounded border border-imu-brand/20 bg-white/90 px-4 py-2 text-sm font-medium text-imu-brand-deep transition hover:border-imu-highlight/60 hover:text-imu-brand"
  >
    {team.more}
  </a>
  <ul class="grid gap-4 sm:grid-cols-2">
    {people.map((person) => <MemberCard person={person} />)}
  </ul>
</Section>
