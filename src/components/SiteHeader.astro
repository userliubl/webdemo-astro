---
import { getLangFromPath, getSiteData } from "@/data/site";
import ThemeToggle from "@/components/ThemeToggle.astro";

const lang = getLangFromPath(Astro.url.pathname);
const { siteMeta, nav, ui } = getSiteData(lang);
const isEn = lang === "en";
---
<header
  data-site-header
  class="sticky top-0 z-50 border-b border-slate-200/90 bg-white/95 font-sans text-slate-900 antialiased backdrop-blur-md shadow-sm shadow-slate-200/40 transition-[box-shadow] duration-300 dark:border-slate-700/90 dark:bg-slate-900/90 dark:text-slate-100 dark:shadow-slate-950/30"
>
  <div data-shell class="mx-auto max-w-5xl px-4 sm:px-6">
    <div class="flex h-[52px] items-center justify-between gap-3">
      <a
        href={import.meta.env.BASE_URL}
        class="flex min-w-0 max-w-[min(100%,14rem)] items-center gap-2.5 text-slate-900 transition hover:text-imu-brand-deep active:scale-[0.99] sm:max-w-none sm:gap-3 dark:text-slate-100 dark:hover:text-imu-400"
        aria-label={`${ui.enterHome}${siteMeta.title}`}
      >
        <img
          src={`${import.meta.env.BASE_URL}${siteMeta.logoSrc.replace(/^\//, "")}`}
          alt={siteMeta.logoAlt}
          width="502"
          height="100"
          class="h-7 w-auto max-w-[140px] shrink-0 object-contain object-left sm:h-8 sm:max-w-[180px] dark:brightness-125"
          fetchpriority="high"
        />
        <span
          data-brand-text
          class="truncate text-sm font-semibold tracking-tight transition-colors duration-200 sm:text-[15px] sm:leading-snug"
        >
          {siteMeta.title}
        </span>
      </a>

      <div class="flex items-center gap-2">
        <ThemeToggle />
        <div data-menu-wrap class="relative shrink-0">
        <button
          type="button"
          data-menu-toggle
          class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-slate-300/90 bg-white text-slate-800 transition duration-300 hover:scale-105 hover:border-imu-highlight/40 hover:bg-slate-50 motion-reduce:hover:scale-100 active:scale-[0.98] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-imu-highlight focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:border-slate-600 dark:bg-slate-800 dark:text-slate-200 dark:hover:border-imu-highlight/40 dark:hover:bg-slate-700 dark:focus-visible:ring-offset-slate-900"
          aria-expanded="false"
          aria-controls="site-nav-dropdown"
          aria-haspopup="true"
          aria-label={ui.menuAria}
        >
          <svg
            data-menu-icon
            width="19"
            height="19"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden
            class="transition-transform duration-300"
          >
            <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"></path>
          </svg>
        </button>

        <div
          id="site-nav-dropdown"
          data-menu-panel
          aria-hidden="true"
          inert
          class="pointer-events-none absolute right-0 top-[calc(100%-10px)] z-50 w-[min(21rem,calc(100vw-2rem))] origin-top-right -translate-y-2 scale-[0.92] rounded-2xl border border-slate-200 bg-white px-2.5 pb-2.5 pt-4 text-slate-900 opacity-0 shadow-2xl shadow-slate-400/25 transition duration-300 motion-reduce:translate-y-0 motion-reduce:scale-100 motion-reduce:transition-opacity dark:border-slate-700 dark:bg-slate-800 dark:text-slate-100 dark:shadow-slate-950/40"
        >
          <nav class="flex flex-col gap-1" aria-label={ui.pageNavAria}>
            {nav.map((item) => (
              <a
                href={`${import.meta.env.BASE_URL}${item.href.replace(/^\//, "")}`}
                data-nav-id={item.id}
                class="group flex origin-left items-start justify-between gap-3 rounded-xl px-3 py-3 text-slate-800 outline-none transition duration-200 hover:scale-[1.02] hover:bg-slate-50 active:bg-slate-100 motion-reduce:hover:scale-100 motion-reduce:transition-colors focus-visible:ring-2 focus-visible:ring-imu-highlight focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:text-slate-200 dark:hover:bg-slate-700/60 dark:active:bg-slate-700 dark:focus-visible:ring-offset-slate-900"
              >
                <div class="min-w-0">
                  <div class="text-sm font-semibold text-slate-900 dark:text-slate-100">{item.label}</div>
                  <div class="mt-1 text-xs leading-relaxed text-slate-500 transition group-hover:text-slate-600 dark:text-slate-400 dark:group-hover:text-slate-300">
                    {item.hint}
                  </div>
                </div>
              </a>
            ))}
          </nav>
          <div class="mt-2 border-t border-slate-200 px-3 pt-2.5 dark:border-slate-700">
            <div class="inline-flex items-center gap-1 rounded-full bg-slate-100 p-0.5 text-[11px] font-semibold dark:bg-slate-700">
              <a
                href={import.meta.env.BASE_URL}
                class={`inline-flex h-6 items-center justify-center rounded-full px-2.5 transition-all duration-200 ${
                  !isEn
                    ? "bg-white text-slate-900 shadow-sm dark:bg-slate-600 dark:text-slate-100"
                    : "text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200"
                }`}
                aria-label="切换到中文"
                aria-current={!isEn ? "page" : undefined}
              >中</a>
              <a
                href={`${import.meta.env.BASE_URL}en/`}
                class={`inline-flex h-6 items-center justify-center rounded-full px-2.5 transition-all duration-200 ${
                  isEn
                    ? "bg-white text-slate-900 shadow-sm dark:bg-slate-600 dark:text-slate-100"
                    : "text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200"
                }`}
                aria-label="Switch to English"
                aria-current={isEn ? "page" : undefined}
              >EN</a>
            </div>
          </div>
        </div>
      </div>
      </div>
    </div>
  </div>
</header>

<script>
  let menuOpen = false;
  let hoverCloseTimer: ReturnType<typeof setTimeout> | null = null;
  let scrollListenersReady = false;

  const fineHover = () =>
    window.matchMedia("(hover: hover) and (pointer: fine)").matches;

  /* ------ scroll lock ------ */
  const lockBodyScroll = () => {
    const scrollY = window.scrollY;
    document.body.style.position = "fixed";
    document.body.style.top = `-${scrollY}px`;
    document.body.style.width = "100%";
    document.body.style.overflowY = "scroll";
  };
  const unlockBodyScroll = () => {
    const top = document.body.style.top;
    document.body.style.position = "";
    document.body.style.top = "";
    document.body.style.width = "";
    document.body.style.overflowY = "";
    if (top) {
      window.scrollTo({ top: -parseFloat(top), behavior: "instant" as ScrollBehavior });
    }
  };

  /* re-query header + shell on every init (DOM may be new after View Transitions) */
  const getHeader = () => document.querySelector<HTMLElement>("[data-site-header]");

  const setMenuOpen = (next: boolean) => {
    menuOpen = next;
    const toggle = getHeader()?.querySelector<HTMLButtonElement>("[data-menu-toggle]");
    const panel = getHeader()?.querySelector<HTMLElement>("[data-menu-panel]");
    const icon = getHeader()?.querySelector<SVGElement>("[data-menu-icon]");
    if (!toggle || !panel || !icon) return;
    toggle.setAttribute("aria-expanded", String(next));
    panel.setAttribute("aria-hidden", String(!next));
    if (next) {
      let backdrop = document.getElementById("menu-backdrop");
      if (!backdrop) {
        backdrop = document.createElement("div");
        backdrop.id = "menu-backdrop";
        backdrop.className = "fixed inset-0 z-40 bg-slate-950/15 backdrop-blur-[1px]";
        backdrop.setAttribute("aria-hidden", "true");
        document.body.appendChild(backdrop);
      }
      backdrop.style.display = "block";
      lockBodyScroll();
      panel.removeAttribute("inert");
      panel.classList.remove("pointer-events-none", "-translate-y-2", "scale-[0.92]", "opacity-0");
      panel.classList.add("translate-y-0", "scale-100", "opacity-100");
      toggle.classList.remove("border-slate-300/90", "bg-white", "hover:border-imu-highlight/40", "hover:bg-slate-50");
      toggle.classList.add("border-imu-highlight/50", "bg-imu-50", "shadow-md", "shadow-imu-brand/10");
      icon.classList.add("rotate-90");
    } else {
      const backdrop = document.getElementById("menu-backdrop");
      if (backdrop) backdrop.style.display = "none";
      unlockBodyScroll();
      panel.setAttribute("inert", "");
      panel.classList.add("pointer-events-none", "-translate-y-2", "scale-[0.92]", "opacity-0");
      panel.classList.remove("translate-y-0", "scale-100", "opacity-100");
      toggle.classList.add("border-slate-300/90", "bg-white", "hover:border-imu-highlight/40", "hover:bg-slate-50");
      toggle.classList.remove("border-imu-highlight/50", "bg-imu-50", "shadow-md", "shadow-imu-brand/10");
      icon.classList.remove("rotate-90");
    }
  };

  const clearHover = () => {
    if (hoverCloseTimer) { clearTimeout(hoverCloseTimer); hoverCloseTimer = null; }
  };

  /* ── init: bind element-specific listeners (re-run after View Transitions) ── */
  function initSiteHeader() {
    /* clean up stale backdrop from previous page */
    const stale = document.getElementById("menu-backdrop");
    if (stale) stale.remove();
    unlockBodyScroll();
    menuOpen = false;

    const header = getHeader();
    if (!header) return;
    const shell = header.querySelector<HTMLElement>("[data-shell]");
    const toggle = header.querySelector<HTMLButtonElement>("[data-menu-toggle]");
    const wrap = header.querySelector<HTMLElement>("[data-menu-wrap]");
    const navItems = Array.from(header.querySelectorAll<HTMLAnchorElement>("[data-nav-id]"));

    /* toggle */
    toggle?.addEventListener("click", () => { clearHover(); setMenuOpen(!menuOpen); });

    /* desktop hover */
    wrap?.addEventListener("mouseenter", () => {
      if (!fineHover()) return;
      clearHover();
      setMenuOpen(true);
    });
    wrap?.addEventListener("mouseleave", () => {
      if (!fineHover()) return;
      clearHover();
      hoverCloseTimer = setTimeout(() => setMenuOpen(false), 160);
    });

    /* nav items */
    navItems.forEach((a) =>
      a.addEventListener("click", (e) => {
        clearHover();
        setMenuOpen(false);
        const href = a.getAttribute("href") || "";
        if ((href.startsWith("/#") || href.startsWith("/en/#")) && (location.pathname === "/" || location.pathname === "/en/")) {
          e.preventDefault();
          const id = href.split("#")[1] || "";
          history.pushState(null, "", href);
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              const el = document.getElementById(id);
              if (!el) return;
              const headerH = header.getBoundingClientRect().height || 52;
              const padTop = parseFloat(getComputedStyle(document.documentElement).scrollPaddingTop) || headerH;
              const offset = Math.max(headerH, padTop);
              const top = el.getBoundingClientRect().top + window.scrollY - offset;
              window.scrollTo({ top: Math.max(0, top), behavior: "smooth" });
            });
          });
        }
      }),
    );

    /* scroll shadow & active section */
    const updateScrollState = () => {
      const isScrolled = window.scrollY > 6;
      header.classList.toggle("shadow-md", isScrolled);
      header.classList.toggle("shadow-slate-300/35", isScrolled);
      header.classList.toggle("shadow-sm", !isScrolled);
      header.classList.toggle("shadow-slate-200/40", !isScrolled);
    };
    const updateActive = () => {
      if (location.pathname !== "/" && location.pathname !== "/en/") return;
      const padTop = parseFloat(getComputedStyle(document.documentElement).scrollPaddingTop) || 52;
      const y = window.scrollY + padTop;
      let current: string | null = null;
      if (window.scrollY >= 72) {
        for (const a of navItems) {
          const id = a.getAttribute("data-nav-id");
          if (!id) continue;
          const el = document.getElementById(id);
          if (el) { const top = el.getBoundingClientRect().top + window.scrollY; if (top <= y) current = id; }
        }
      }
      navItems.forEach((a) => {
        const id = a.getAttribute("data-nav-id");
        const active = id === current;
        a.classList.toggle("bg-imu-50", active);
        a.classList.toggle("text-imu-950", active);
        a.classList.toggle("ring-1", active);
        a.classList.toggle("ring-imu-highlight/45", active);
      });
    };
    updateScrollState();
    updateActive();
    if (!scrollListenersReady) {
      scrollListenersReady = true;
      window.addEventListener("scroll", updateScrollState, { passive: true });
      window.addEventListener("scroll", updateActive, { passive: true });
      window.addEventListener("resize", updateActive, { passive: true });
    }
  }

  /* ── document-level listeners (attach once) ── */
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && menuOpen) setMenuOpen(false);
  });
  document.addEventListener(
    "pointerdown",
    (e) => {
      if (!menuOpen) return;
      const target = e.target as HTMLElement;
      if (target.id === "menu-backdrop") { setMenuOpen(false); return; }
      const header = getHeader();
      const shell = header?.querySelector<HTMLElement>("[data-shell]");
      if (!shell?.contains(target)) setMenuOpen(false);
    },
    { capture: true },
  );

  /* ── run ── */
  initSiteHeader();
  document.addEventListener("astro:page-load", initSiteHeader);
</script>
