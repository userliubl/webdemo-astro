---
type Variant = "light" | "brand";
interface Props {
  id: string;
  title: string;
  eyebrow?: string;
  variant?: Variant;
  hasAction?: boolean;
}
const { id, title, eyebrow, variant = "light", hasAction = false } = Astro.props;
const isBrand = variant === "brand";
const shell = isBrand
  ? "relative border-b border-white/10 bg-brand-photo bg-cover bg-center px-4 py-14 sm:px-6 sm:py-16"
  : "relative border-b border-slate-200/80 bg-slate-50/78 px-4 py-14 backdrop-blur-[2px] sm:px-6 sm:py-16 dark:border-slate-700/80 dark:bg-slate-900/60";
const eyebrowCls = isBrand ? "text-white/65" : "text-imu-brand-deep dark:text-imu-400";
const titleCls = isBrand ? "text-white" : "text-slate-900 dark:text-slate-100";
const barCls = isBrand ? "border-l-[3px] border-white/90" : "border-l-[3px] border-imu-highlight";
---
<section id={id} class={shell}>
  {!isBrand && (
    <div
      aria-hidden
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_12%_18%,rgba(4,107,167,0.065),transparent_18%),radial-gradient(circle_at_88%_82%,rgba(4,107,167,0.05),transparent_22%)]"
    />
  )}
  <div class="mx-auto max-w-5xl">
    {hasAction ? (
      <div class="mb-9 flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between sm:gap-8">
        <div class="min-w-0 flex-1">
          <div class={`max-w-2xl ${barCls} pl-[1.125rem]`}>
            {eyebrow && <p class={`mb-1 font-mono text-xs uppercase tracking-widest ${eyebrowCls}`}>{eyebrow}</p>}
            <h2 class={`text-2xl font-semibold tracking-tight sm:text-3xl ${titleCls}`}>{title}</h2>
          </div>
        </div>
        <div class="shrink-0 sm:max-w-[40%] sm:pt-1 sm:text-right">
          <slot name="action" />
        </div>
      </div>
    ) : (
      <div class="mb-9">
        <div class={`max-w-2xl ${barCls} pl-[1.125rem]`}>
          {eyebrow && <p class={`mb-1 font-mono text-xs uppercase tracking-widest ${eyebrowCls}`}>{eyebrow}</p>}
          <h2 class={`text-2xl font-semibold tracking-tight sm:text-3xl ${titleCls}`}>{title}</h2>
        </div>
      </div>
    )}
    <slot />
  </div>
</section>
